      ]
    },
    {
      "name": "Favorites",
      "item": [
        {
          "name": "Get Favorites",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/favorites"
          }
        },
        {
          "name": "Add Favorite",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/favorites/{{workoutId}}"
          }
        },
        {
          "name": "Remove Favorite",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/favorites/{{workoutId}}"
          }
        }
