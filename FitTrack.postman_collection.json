          }
        },
        {
          "name": "Claim Achievement",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/achievements/claim/{{achievementId}}"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Get AI Chat",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/ai/chat"
          }
        },
        {
          "name": "Send AI Chat",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/ai/chat",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"user\",\n  \"message\": \"Halo AI\"\n}"
            }
          }
