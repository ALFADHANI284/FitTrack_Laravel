              "raw": "{\n  \"measured_at\": \"2026-05-21\",\n  \"weight_kg\": 72.5,\n  \"body_fat_percentage\": 18.2\n}"
            }
          }
        },
        {
          "name": "Update Progress",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/progress/{{progressId}}",
