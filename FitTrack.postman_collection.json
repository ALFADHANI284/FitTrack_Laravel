          "name": "Get AI Personalization",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/ai/personalization"
          }
        },
        {
          "name": "Create AI Personalization",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/ai/personalization",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preferences\": {\n    \"goal\": \"fat_loss\",\n    \"level\": \"beginner\"\n  }\n}"
            }
          }
        },
        {
          "name": "Delete AI Personalization",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/ai/personalization"
          }
