            "url": "{{baseUrl}}/api/reminders/{{reminderId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Reminder\"\n}"
            }
          }
        },
        {
          "name": "Delete Reminder",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/reminders/{{reminderId}}"
          }
        }
      ]
    },
    {
      "name": "Progress",
      "item": [
        {
          "name": "Get Progress",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/progress"
          }
        },
        {
          "name": "Add Progress",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/progress",
